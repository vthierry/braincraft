prgm_default_options := table([(omega)=1000,(python)=true,(all_neuronoid)=false
]);
prgm_functions := {And = (() -> H(sum(_passed[k],k = 1 .. _npassed)-_npassed+.5
)), Delay = proc (o, i, T) local v, g; v := prgm_new_symbol("v"); g := if 0 < T
then 1-2^(-1/T) else 1 end if; v = (1-g)*v+g*i, o = If_b(.5 < v,1,0) end proc,
Exp_v = (v -> .1821429756+2.339035264*h(v-1)+1.551573291*h(1/2*v)), H = (v -> 
if type(v,`<=`) then H(H(op(1,v)-op(2,v))) elif type(v,`<`) then Not(H(op(2,v)
<= op(1,v))) elif type(v,`=`) then And(H(op(1,v) <= op(2,v)),H(op(2,v) <= op(1,
v))) elif type(v,`<>`) then Not(H(op(1,v) = op(2,v))) elif prgm_options[
all_neuronoid] then h(omega*v-.5) elif type(v,constant) then Heaviside(v) else
H(v) end if), Id = (v -> if prgm_options[all_neuronoid] then omega*h(v/omega) 
else h(v) end if), If_b = ((c, b1, b0) -> if _npassed = 3 then H(b0-c-.5)+H(b1+
c-3/2) else If_b(c,b1,If_b(_passed[3 .. _npassed])) end if), If_v = ((c, v1, v0
) -> if _npassed = 3 then Bprod(c,v1,1-c,v0) else If_v(c,v1,If_v(_passed[3 .. 
_npassed])) end if), Latch_b = ((o, b_1, b_c) -> o = If_b(b_c = 1,o,b_1)), 
Latch_v = ((o, v_1, v_c) -> o = If_v(b_c = 1,o,v_1)), Log_v = (v -> -5.10355578\
9+2.597614937*h(1/2*v)+4.702926636*h(1/10*v)), Not = (v -> H(1-v)), Or = (() ->
H(sum(_passed[k],k = 1 .. _npassed)+.5)), Prod_b = (() -> if type(_npassed,odd)
then Bprod(_passed,0) else sum(omega*h(_passed[2*i]/omega+omega(_passed[2*i]-1)
),k = 1 .. 1/2*_npassed) end if), Prod_v = ((v1, v2) -> evalf(subs({b = 4/(exp(
1)-1)^2, c = coth(.5), l = (v -> Log_v(1/2*(exp(1)-1)*v+1/2*exp(1)+1/2))},b*
Exp_v(l(v1)+l(v2))-c*(v1+v2+c)))), Softmax = proc () local k, g, b; g := 
_passed[_npassed]; b := proc (k, a) local l; H(add(H(a[l] < a[k]),l = 1 .. k-1)
+add(H(a[l] <= a[k]),l = k+1 .. nops(a))-nops(a)+3/2) end proc; add((g/_npassed
+(1-g)*b(k,[_passed[1 .. _npassed-1]]))*_passed[k],k = 1 .. _npassed-1) end 
proc, Spikeup = proc (o, i) local r; r := prgm_new_symbol("r"); r = If_b(o = 1,
1,i = 0,0,r), o = If_b(And(r = 0,i = 1),1,0) end proc, h = (v -> if type(v,
constant) then 1/(1+exp(-4*x)) else h(v) end if), Bistable = proc (o, i) if 
_npassed = 3 then o = If_b(And(o = 0,_passed[2] = 1),1,And(o = 1,_passed[3] = 0
),0,o) else proc (o, i) local i0, i1; i0 := prgm_new_symbol("i0"); i1 := 
prgm_new_symbol("i1"); i1 = If_b(And(i1 = 0,i = 1),1,o = 0,0,i1), i0 = If_b(And
(i0 = 0,i = 0),1,o = 1,0,i0), o = If_b(And(o = 0,i1 = 1),1,And(o = 1,i0 = 0),0,
0) end proc(o,i) end if end proc, Oscillator = proc (o, c, T) local v, gamma; v
:= prgm_new_symbol("v"); gamma := if 0 < T then 2-2^(1-1/T) else 2 end if; v =
(1-g)*v+g*(1-o)*c, o = If_b(v < 1/3,0,0,2/3 < v,1,o) end proc};
prgm_compile := proc (prgm_file::string) local prgm, new_symbol, 
new_symbol_count; prgm := table(); new_symbol_count := 0; try prgm["options"] 
:= proc () global prgm_default_options; op(prgm_default_options) end proc(); 
prgm["options"][file] := prgm_file; prgm["options"][name] := FileTools[Basename
](prgm_file); prgm["options"][version] := convert(Date(),string); if not 
FileTools[Exists](prgm["options"][file]) then error cat(
"Syntax error: The file '",prgm["options"][file],"' does not exist, it must.")
end if; prgm["source"] := FileTools[Text][ReadFile](prgm["options"][file]); 
prgm["input"] := parse(StringTools[RegSubs]("#[^\n]*\n" = "",prgm["source"]));
if type(prgm["input"],list) and 0 < nops(prgm["input"]) then if type(op(1,prgm[
"input"]),`=`) and op(1,op(1,prgm["input"])) = prgm_options then if type(op(2,
op(1,prgm["input"])),{list, set}) then map(o -> if type(o,`=`) then prgm[
"options"][op(1,o)] := op(2,o) else prgm["options"][o] := true end if,op(2,op(1
,prgm["input"]))) else error 
"Syntax error: The prgm_options is not a set or a list, it must." end if; prgm[
"input"] := [op(2 .. nops(prgm["input"]),prgm["input"])] end if; map(eq -> if 
type(eq,`=`) and op(1,eq) = prgm_options then error 
"Syntax error: A prgm_options is not given at the 1st line, it must." end if,
prgm["input"]) else error 
"Syntax error: The sourc file content is not a non empty list, it must." end if
; proc (eqs) local function_names, alert; global prgm_functions; function_names
:= map(eq -> op(1,eq),prgm_functions); alert := e -> if e then error cat(
"Syntax error: ",op(map(a -> convert(a,string),[_passed[2 .. nops([_passed])]])
)) end if; alert(not type(eqs,list),"The  input is not a list (of equations)");
map(proc (l, eqs) local eq; eq := eqs[l]; if type(eq,`=`) then alert(not type(
op(1,eq),name),"The left hand side of '",eq,"', line number '",l,
"' is not a name"); alert(type(op(2,eq),function) and not op(0,op(2,eq)) in 
function_names,"The right hand side of '",eq,"', line number '",l,
"' is not a known function") else alert(not (type(eq,function) and op(0,eq) in
function_names),"The '",eq,"', line number '",l,"' is not a known function") 
end if end proc,[$ 1 .. nops(eqs)],eqs) end proc(prgm["input"]); new_symbol :=
proc (prefix::string) new_symbol_count := new_symbol_count+1; convert(cat(
prefix,"_",new_symbol_count),name) end proc; prgm["expanded"] := proc (prgm) 
local fixed_point; fixed_point := proc (f, v_0, context, max_iterations::posint
:= 10) local v0, v1, t; v0 := null; v1 := v_0; for t to max_iterations do v0 :=
f(v1,context); if v0 = v1 then return v0 end if; v1 := v0 end do; error 
"Iteratively expanding toward a fixed point failed." end proc; evalf(
fixed_point(proc (eqs, prgm) global prgm_function; eval(subs(subs(prgm_options
= prgm["options"],prgm_new_symbol = new_symbol,prgm_functions),eqs)) end proc,
prgm["input"],prgm)) end proc(prgm); prgm["flattened"] := proc (eqs0) local 
eqs1, eqs2, expand_args, expand_arg; eqs2 := []; expand_args := a -> if type(a,
{`*`, `+`, function}) then op(0,a)(op(map(expand_arg,a))) else a end if; 
expand_arg := proc (a) local n, a_n; if type(a,function) then a_n := 
expand_args(a); n := new_symbol("x"); eqs2 := [n = a_n, op(eqs2)]; n elif type(
a,{`*`, `+`}) then expand_args(a) else a end if end proc; eqs1 := map(eq -> if
type(eq,`=`) then op(1,eq) = expand_args(op(2,eq)) else error cat(
"After expanding one line: '",eq,"' is not an equation") end if,eqs0); [op(eqs2
), op(eqs1)] end proc(prgm["expanded"]); if prgm["options"][python] then prgm[
"python"] := proc (prgm) local c, w; w := interface(warnlevel = 0); c := 
StringTools[RegSubs]("^" = "\t",StringTools[RegSubs]("\n(.)" = "\n\t\\1",
CodeGeneration[Python](prgm["flattened"],defaulttype = float,output = string)))
; interface(warnlevel = w); c := cat("# This file is automatically generated by\
 the programmatoid compiler, better not edit\n","\ndef ",prgm["options"][name],
"(state)\n",if not prgm["options"][all_neuronoid] then cat(
"\n\tdef H(x):\n\t\treturn 0 if x < 0 else 1 if x > 0 else 1/2\t\n",
"\n\tdef Id(x):\n\t\treturn x\n") else "" end if,
"\n\tdef h(x):\n\t\treturn 1 / (1 + np.exp(-4 * x))\n","\n",c,"\n"); FileTools[
Text][WriteFile](StringTools[RegSubs](".mpl$" = ".py",prgm["options"][file]),c)
; c end proc(prgm) end if catch: prgm["error"] := lastexception; return prgm 
end try; prgm end proc;
